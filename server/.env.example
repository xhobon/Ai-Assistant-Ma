DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ai_assistant"
JWT_SECRET="change_me_to_random_string"
GROQ_API_KEY="gsk_xxx"
PORT=8080
CORS_ORIGIN="*"
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="AI助手 <no-reply@yourdomain.com>"
AUTH_DEBUG_RETURN_CODE=0
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="xxx"

# 翻译链路（Vercel -> Ollama）
# 示例: http://123.123.123.123:11434
OLLAMA_API="http://127.0.0.1:11434"
# 兼容别名：未设置 OLLAMA_API 时，会尝试 OLLAMA_BASE_URL 或 OPENAI_API_BASE
OLLAMA_BASE_URL=""
# 翻译模型，默认 qwen2.5:3b
OLLAMA_TRANSLATE_MODEL="qwen2.5:3b"
